/* ─── ROUTE OPTIMISATION ─────────────────── */
let routeOptOrders=[];
async function renderRouteOptimisation(myActive){
  const card=document.getElementById('routeOptCard');
  if(myActive.length<2){if(card)card.style.display='none';if(routeMapInstance){routeMapInstance.remove();routeMapInstance=null;}return;}
  if(card)card.style.display='block';
  routeOptOrders=myActive;

  // Build stops list
  const stopListEl=document.getElementById('routeStopList');
  if(!stopListEl)return;
  let stopsHtml='';
  let stopNum=1;
  for(const[key,o]of myActive){
    const ra=getRestaurantAddrSync(o)||'Restaurant';
    stopsHtml+=`<div class="route-stop"><div class="route-stop-num pickup">${stopNum++}</div><div class="route-stop-info"><div class="route-stop-type" style="color:rgba(255,255,255,.5)">Pickup · ${o.vendorName||'Restaurant'}</div><div class="route-stop-addr">${ra}</div></div></div>`;
    if(o.status==='out_for_delivery'){
      const ca=getCustomerAddr(o)||'Customer';
      stopsHtml+=`<div class="route-stop"><div class="route-stop-num delivery">${stopNum++}</div><div class="route-stop-info"><div class="route-stop-type" style="color:rgba(255,255,255,.5)">Delivery · ${getCustomerName(o)}</div><div class="route-stop-addr">${ca}</div></div></div>`;
    }
  }
  stopListEl.innerHTML=stopsHtml;

  // Build route on map
  setTimeout(async()=>{
    const mapEl=document.getElementById('routeOptMap');
    if(!mapEl)return;
    if(routeMapInstance){routeMapInstance.remove();routeMapInstance=null;}
    try{
      const map=new mapboxgl.Map({container:'routeOptMap',style:'mapbox://styles/mapbox/dark-v11',center:[28.4,-25.7],zoom:11});
      routeMapInstance=map;
      map.on('load',async()=>{
        map.resize();
        const coords=[];
        const colors={pickup:'#1a7a4a',delivery:'#ff751f'};
        for(const[key,o]of myActive){
          const ra=getRestaurantAddrSync(o);
          if(ra){const g=await geocode(ra);if(g){new mapboxgl.Marker({color:colors.pickup}).setLngLat([g.lng,g.lat]).addTo(map);coords.push([g.lng,g.lat]);}}
          if(o.status==='out_for_delivery'){const ca=getCustomerAddr(o);if(ca){const g=await geocode(ca);if(g){new mapboxgl.Marker({color:colors.delivery}).setLngLat([g.lng,g.lat]).addTo(map);coords.push([g.lng,g.lat]);}}}
        }
        if(coords.length>=2){
          const coordStr=coords.map(c=>c.join(',')).join(';');
          try{
            const r=await fetch(`https://api.mapbox.com/directions/v5/mapbox/driving/${coordStr}?geometries=geojson&overview=full&access_token=${MAPBOX_TOKEN}`);
            const d=await r.json();
            if(d.routes&&d.routes[0]){
              map.addSource('opt-route',{type:'geojson',data:{type:'Feature',properties:{},geometry:d.routes[0].geometry}});
              map.addLayer({id:'opt-route',type:'line',source:'opt-route',layout:{'line-join':'round','line-cap':'round'},paint:{'line-color':'#ff751f','line-width':4,'line-opacity':.85,'line-dasharray':[1,0]}});
              const bounds=coords.reduce((b,c)=>b.extend(c),new mapboxgl.LngLatBounds(coords[0],coords[0]));
              map.fitBounds(bounds,{padding:30});
            }
          }catch(e){}
        }else if(coords.length===1){map.setCenter(coords[0]);map.setZoom(13);}
      });
    }catch(e){console.error('Route map error:',e);}
  },300);
}

window.openGoogleMapsRoute=async function(){
  if(!routeOptOrders.length)return;
  const waypoints=[];
  for(const[key,o]of routeOptOrders){
    const ra=getRestaurantAddrSync(o);if(ra)waypoints.push(ra);
    if(o.status==='out_for_delivery'){const ca=getCustomerAddr(o);if(ca)waypoints.push(ca);}
  }
  if(!waypoints.length)return;
  const dest=encodeURIComponent(waypoints[waypoints.length-1]);
  const wps=waypoints.slice(0,-1).map(w=>`via:${encodeURIComponent(w)}`).join('|');
  const url=`https://www.google.com/maps/dir/?api=1&destination=${dest}${wps?'&waypoints='+wps:''}`;
  window.open(url,'_blank');
};

