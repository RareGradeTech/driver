window.openProofModal=function(key){
  proofOrderKey=key;
  proofUploadedUrl=null;
  const o=ordersCache[key];
  // If already has proof, skip upload and just mark delivered
  if(o&&o.deliveryProofUrl){
    if(confirm('Proof already uploaded. Confirm delivery?')){markDeliveredWithProof(key,o.deliveryProofUrl);}
    return;
  }
  // Reset modal
  document.getElementById('proofPreviewImg').classList.remove('show');
  document.getElementById('proofPreviewImg').src='';
  document.getElementById('proofUploadPrompt').style.display='block';
  document.getElementById('proofUploadArea').classList.remove('has-photo');
  document.getElementById('proofUploading').classList.remove('show');
  document.getElementById('proofSuccessBlock').style.display='none';
  document.getElementById('confirmDeliveredBtn').disabled=true;
  document.getElementById('proofFileInput').value='';
  openModal('proofModal');
};

window.handleProofPhoto=async function(input){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  if(file.size>10*1024*1024){showToast('Photo too large — max 10MB','error');return;}

  // Show preview immediately
  const reader=new FileReader();
  reader.onload=e=>{
    const img=document.getElementById('proofPreviewImg');
    img.src=e.target.result;
    img.classList.add('show');
    document.getElementById('proofUploadPrompt').style.display='none';
  };
  reader.readAsDataURL(file);

  // Upload to Cloudinary
  document.getElementById('proofUploading').classList.add('show');
  document.getElementById('proofUploadArea').classList.remove('has-photo');

  try{
    const fd=new FormData();
    fd.append('file',file);
    fd.append('upload_preset',CLOUDINARY_PRESET);
    fd.append('folder','1busket_delivery_proofs');

    const res=await fetch(`https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD}/image/upload`,{method:'POST',body:fd});
    const data=await res.json();

    if(data.secure_url){
      proofUploadedUrl=data.secure_url;
      document.getElementById('proofUploading').classList.remove('show');
      document.getElementById('proofSuccessBlock').style.display='block';
      document.getElementById('proofUploadArea').classList.add('has-photo');
      document.getElementById('confirmDeliveredBtn').disabled=false;
    }else{throw new Error('Upload failed');}
  }catch(e){
    document.getElementById('proofUploading').classList.remove('show');
    showToast('Upload failed — try again','error');
    document.getElementById('proofPreviewImg').classList.remove('show');
    document.getElementById('proofUploadPrompt').style.display='block';
    document.getElementById('proofFileInput').value='';
  }
};

window.submitProofAndDeliver=async function(){
  if(!proofOrderKey||!proofUploadedUrl){showToast('Please upload a photo first','error');return;}
  document.getElementById('confirmDeliveredBtn').disabled=true;
  document.getElementById('confirmDeliveredBtn').innerHTML='<span style="opacity:.65">Confirming…</span>';
  await markDeliveredWithProof(proofOrderKey,proofUploadedUrl);
  hideModal('proofModal');
};

async function markDeliveredWithProof(key,photoUrl){
