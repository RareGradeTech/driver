function updateEarningsTab(){
  const orders=Object.values(ordersCache).filter(o=>o.driverKey===DRIVER_KEY&&o.status==='delivered');
  const now=new Date();const todayStr=now.toDateString();
  const weekStart=new Date(now);weekStart.setDate(now.getDate()-now.getDay());
  const monthStart=new Date(now.getFullYear(),now.getMonth(),1);
  const todayE=orders.filter(o=>new Date(o.createdAt).toDateString()===todayStr).reduce((s,o)=>s+Number(o.total||0)*0.15,0);
  const weekE=orders.filter(o=>new Date(o.createdAt)>=weekStart).reduce((s,o)=>s+Number(o.total||0)*0.15,0);
  const monthE=orders.filter(o=>new Date(o.createdAt)>=monthStart).reduce((s,o)=>s+Number(o.total||0)*0.15,0);
  const set=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v;};
  set('earningsToday','R '+todayE.toFixed(2));set('earningsWeek','R '+weekE.toFixed(2));set('earningsMonth','R '+monthE.toFixed(2));set('totalDelivered',orders.length);
}

