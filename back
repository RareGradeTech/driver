/* ─── HELPERS ────────────────────────────── */
function getDriverFullName(d){if(!d)return'Driver';if(d.name&&d.name.trim())return d.name.trim();const f=d.firstName?d.firstName.trim():'',l=d.lastName?d.lastName.trim():'';return(f+' '+l).trim()||'Driver';}
function getCustomerName(o){return o.customerName||o.userName||(typeof o.customer==='string'?o.customer:null)||(o.userEmail?o.userEmail.split('@')[0]:null)||'Customer';}
function getRestaurantAddrSync(o){let a=o.vendorAddress||o.restaurantAddress||o.vendorLocation||(o.vendor&&(o.vendor.address||o.vendor.location))||o.pickupAddress||o.storeAddress;if(a&&a.trim())return a.trim();if(o.vendorKey&&vendorCache[o.vendorKey])return vendorCache[o.vendorKey];return null;}
function getCustomerAddr(o){return o.deliveryAddress||o.address||o.customerAddress||o.shippingAddress||o.fullAddress||o.dropoffAddress||o.destination||(o.location&&(typeof o.location==='string'?o.location:o.location.address))||(o.customer&&typeof o.customer==='object'?o.customer.address:null)||null;}
async function getVendorAddr(vk){if(!vk||vendorCache[vk]!==undefined)return vendorCache[vk]||null;try{const snap=await db.ref('vendors/'+vk).once('value');const v=snap.val();if(v&&v.address){const a=[v.address.street,v.address.suburb,v.address.city,v.address.province].filter(Boolean).join(', ')||v.address.fullAddress||null;vendorCache[vk]=a;return a;}if(v&&v.location&&typeof v.location==='string'){vendorCache[vk]=v.location;return v.location;}}catch(e){}vendorCache[vk]=null;return null;}

/* ─── GEOCODE ────────────────────────────── */
async function geocode(addr){
  if(!addr)return null;
  if(gcCache[addr])return gcCache[addr];
  try{const r=await fetch(`https://api.mapbox.com/search/geocode/v6/forward?q=${encodeURIComponent(addr)}&access_token=${MAPBOX_TOKEN}&limit=1&country=ZA`);const d=await r.json();if(d.features&&d.features.length>0){const[lng,lat]=d.features[0].geometry.coordinates;gcCache[addr]={lat,lng};return{lat,lng};}}catch(e){}return null;
}

/* ─── LOCATION ───────────────────────────── */
function startLocationWatch(){
  if(!navigator.geolocation){locationError='Geolocation not supported';updateLocBanners('error');renderDashboard();return;}
  updateLocBanners('fetching');
  navigator.geolocation.getCurrentPosition(pos=>{
    driverLat=pos.coords.latitude;driverLng=pos.coords.longitude;locationError=null;
    updateLocBanners('success');
    if(DRIVER_KEY&&isOnline)db.ref('drivers/'+DRIVER_KEY).update({lastLat:driverLat,lastLng:driverLng,lastSeen:Date.now()});
    renderDashboard();
  },err=>{locationError=err.code===1?'Location denied. Showing all orders.':'Could not get location.';updateLocBanners('error');renderDashboard();},{enableHighAccuracy:true,timeout:10000,maximumAge:30000});
  if(locationWatcher)navigator.geolocation.clearWatch(locationWatcher);
  locationWatcher=navigator.geolocation.watchPosition(pos=>{
    driverLat=pos.coords.latitude;driverLng=pos.coords.longitude;
    if(DRIVER_KEY&&isOnline)db.ref('drivers/'+DRIVER_KEY).update({lastLat:driverLat,lastLng:driverLng,lastSeen:Date.now()});
    updateLocBanners('success');
  },()=>{},{enableHighAccuracy:true,maximumAge:60000});
}

function updateLocBanners(state){
  const b1=document.getElementById('locationBanner'),b2=document.getElementById('locationBanner2');
  const ms=document.getElementById('mobLocStatus');
  [b1,b2].forEach(b=>{if(b)b.style.display='none';});
  if(state==='fetching'){
    const html=`<i data-lucide="loader" style="width:18px;height:18px;animation:spin 1s linear infinite"></i> Getting your location…`;
    [b1,b2].forEach(b=>{if(!b)return;b.className='location-banner';b.style.display='flex';b.innerHTML=html;});
    if(ms)ms.innerHTML=`<i data-lucide="map-pin" style="width:12px;height:12px"></i> Locating…`;
  }else if(state==='success'){
    if(!locBannerShown){[b1,b2].forEach(b=>{if(!b)return;b.className='location-banner success';b.style.display='flex';b.innerHTML=`<i data-lucide="check-circle" style="width:18px;height:18px"></i> Showing all available orders`;});setTimeout(()=>{[b1,b2].forEach(b=>{if(b)b.style.display='none';});},4000);locBannerShown=true;}
    if(ms)ms.innerHTML=`<i data-lucide="map-pin" style="width:12px;height:12px"></i> Located`;
  }else if(state==='error'){
    const html=`<i data-lucide="alert-circle" style="width:18px;height:18px"></i> ${locationError}`;
    [b1,b2].forEach(b=>{if(!b)return;b.className='location-banner error';b.style.display='flex';b.innerHTML=html;});
    if(ms)ms.innerHTML=`<i data-lucide="alert-circle" style="width:12px;height:12px"></i> No location`;
  }
  lucide.createIcons();
}

