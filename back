async function renderLeaderboard(){
  const container=document.getElementById('leaderboardList');
  if(!container)return;

  // Get all drivers from Firebase
  let driversSnap;
  if(!isOnline){container.innerHTML=`<div class="empty-state"><div style="font-size:2rem;margin-bottom:8px">📡</div><div style="font-weight:700">Offline — leaderboard unavailable</div></div>`;return;}
  try{driversSnap=await db.ref('drivers').orderByChild('status').equalTo('active').once('value');}
  catch(e){container.innerHTML=`<div class="empty-state"><div style="font-size:2rem;margin-bottom:8px">⚠️</div><div style="font-weight:700">Could not load leaderboard</div></div>`;return;}

  const driversRaw=driversSnap.val()||{};
  const orders=Object.values(ordersCache);
  const now=new Date();
  const monthStart=new Date(now.getFullYear(),now.getMonth(),1);

  // Build driver scores
  let board=Object.entries(driversRaw).map(([key,d])=>{
    const myOrders=orders.filter(o=>o.driverKey===key&&o.status==='delivered'&&new Date(o.createdAt)>=monthStart);
    const deliveries=myOrders.length;
    const earnings=myOrders.reduce((s,o)=>s+Number(o.total||0)*0.15,0);
    return{key,name:getDriverFullName(d),province:d.province||'',rating:d.rating||5.0,deliveries,earnings,isMe:key===DRIVER_KEY};
  });

  // Filter by province
  if(selectedProvince)board=board.filter(d=>d.province===selectedProvince);

  // Sort by deliveries desc, then earnings
  board.sort((a,b)=>b.deliveries-a.deliveries||b.earnings-a.earnings);

  // Top 10
  board=board.slice(0,10);

  if(!board.length){container.innerHTML=`<div class="empty-state"><div style="font-size:2rem;margin-bottom:8px">🏆</div><div style="font-weight:700">No drivers in ${selectedProvince||'this area'} yet</div></div>`;return;}

  const trophies=['🥇','🥈','🥉'];
  container.innerHTML=board.map((d,i)=>{
    const rank=i+1;
    const rankCls=rank<=3?`rank-${rank}`:'';
    const rankDot=rank<=3?trophies[i]:`#${rank}`;
    const rankEl=rank<=3?`<div class="leaderboard-trophy">${trophies[i]}</div>`:`<div class="leaderboard-rank leaderboard-rank-default">#${rank}</div>`;
    const meBadge=d.isMe?`<span class="you-badge">YOU</span>`:'';
    const init=d.name.charAt(0).toUpperCase();
    return`<div class="leaderboard-row ${rankCls}${d.isMe?' is-me':''}">
      ${rankEl}
      <div class="leaderboard-avatar">${init}</div>
      <div class="leaderboard-info">
        <div class="leaderboard-name">${d.name}${meBadge}</div>
        <div class="leaderboard-sub">${d.province||'SA'} · ★ ${Number(d.rating).toFixed(1)}</div>
      </div>
      <div class="leaderboard-score">
        <div class="leaderboard-deliveries">${d.deliveries} <span style="font-size:.7rem;font-weight:600;color:var(--dim)">del.</span></div>
        <div class="leaderboard-earn">+R${d.earnings.toFixed(0)}</div>
      </div>
    </div>`;
  }).join('');
}

