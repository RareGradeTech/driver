    await db.ref('orders/'+key).update({status:'delivered',deliveryProofUrl:photoUrl,deliveredAt:Date.now(),updatedAt:Date.now()});
    showToast('Delivery confirmed with photo proof! 🎉','success');
  }catch(e){showToast('Failed to confirm delivery','error');}
}

