  let addrHTML=isMyDel
    ?`<div class="order-detail-section"><h4>① Pickup — Restaurant Location</h4><div class="addr-display pickup"><i data-lucide="store" style="width:18px;height:18px;color:#1a7a4a;flex-shrink:0"></i><div><div style="font-size:.72rem;font-weight:700;color:#1a7a4a;margin-bottom:3px">Go here first to collect the order</div><div style="font-weight:700;color:#14532d">${ra}</div></div></div></div><div class="order-detail-section"><h4>② Deliver — Customer Address</h4><div class="addr-display delivery"><i data-lucide="map-pin" style="width:18px;height:18px;color:var(--accent);flex-shrink:0"></i><div><div style="font-size:.72rem;font-weight:700;color:var(--accent);margin-bottom:3px">Deliver here</div><div style="font-weight:700;color:var(--text)">${ca||'Address not provided'}</div></div></div></div>`
    :`<div class="order-detail-section"><h4>Restaurant Pickup Location</h4><div class="addr-display pickup"><i data-lucide="store" style="width:18px;height:18px;color:#1a7a4a;flex-shrink:0"></i><div><div style="font-size:.72rem;font-weight:700;color:#1a7a4a;margin-bottom:3px">Go here to collect the order</div><div style="font-weight:700;color:#14532d">${ra}</div></div></div></div><div class="order-detail-section"><h4>Customer Delivery Address</h4><div class="addr-display locked"><i data-lucide="lock" style="width:18px;height:18px;color:#92400e;flex-shrink:0"></i><div style="color:#92400e;font-size:.84rem;font-weight:600">Accept this order to reveal the customer's delivery address</div></div></div>`;
  const navTarget=isMyDel?(ca||ra):ra;
  const navLabel=isMyDel?'Navigate to Customer':'Navigate to Restaurant';
  const itemsHTML=items.map(it=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:.85rem"><span>${it.name} ×${it.quantity||1}</span><span style="font-weight:700">R${(Number(it.price||0)*(it.quantity||1)).toFixed(2)}</span></div>`).join('');
  document.getElementById('orderDetailTitle').textContent=`Order #${orderNum}`;
  document.getElementById('orderDetailBody').innerHTML=`
    <div class="order-detail-section"><h4>Customer</h4><div class="addr-display"><i data-lucide="user" style="width:18px;height:18px"></i><strong>${customer}</strong></div></div>
    ${addrHTML}
    ${proofSection}
    <div class="order-detail-section"><h4>Order Items</h4>${itemsHTML||'<p style="color:var(--dim);font-size:.85rem">No items listed</p>'}<div style="display:flex;justify-content:space-between;padding:10px 0 0;font-weight:800;font-size:.95rem"><span>Total</span><span style="color:var(--accent)">R${total}</span></div></div>
    <div class="order-detail-section"><h4>Directions Map</h4><div class="map-container"><div id="orderMap"></div></div><div style="margin-top:10px;display:flex;gap:10px">
      <button onclick="window.open('https://www.google.com/maps/dir/?api=1&destination='+encodeURIComponent('${(navTarget||'').replace(/'/g,"\\'")}'),'_blank')" class="btn-primary" style="flex:1;justify-content:center;padding:10px;font-size:.82rem"><i data-lucide="navigation" style="width:14px;height:14px"></i> ${navLabel}</button>
      ${isMyDel&&o.status==='out_for_delivery'?`<button onclick="hideModal('orderDetailModal');openProofModal('${key}')" class="btn btn-success" style="padding:10px 16px;font-size:.82rem"><i data-lucide="camera" style="width:14px;height:14px"></i> Add Proof</button>`:''}
    </div></div>`;
  openModal('orderDetailModal');lucide.createIcons();
  setTimeout(()=>{
    if(currentMapInstance){currentMapInstance.remove();currentMapInstance=null;}
    try{
      const map=new mapboxgl.Map({container:'orderMap',style:'mapbox://styles/mapbox/streets-v12',center:[28.4,-25.7],zoom:11});
      currentMapInstance=map;map.on('load',()=>map.resize());
      if(o.vendorLat&&o.vendorLng){const vl=[parseFloat(o.vendorLng),parseFloat(o.vendorLat)];new mapboxgl.Marker({color:'#1a7a4a'}).setLngLat(vl).setPopup(new mapboxgl.Popup().setHTML(`<strong>🏪 ${o.vendorName||'Restaurant'}</strong><br>${ra}`)).addTo(map);map.setCenter(vl);}
      else if(ra&&ra!=='Restaurant pickup location'){geocode(ra).then(geo=>{if(geo&&currentMapInstance){new mapboxgl.Marker({color:'#1a7a4a'}).setLngLat([geo.lng,geo.lat]).addTo(currentMapInstance);currentMapInstance.setCenter([geo.lng,geo.lat]);}});}
      if(isMyDel&&ca){geocode(ca).then(geo=>{if(!geo||!currentMapInstance)return;new mapboxgl.Marker({color:'#ff751f'}).setLngLat([geo.lng,geo.lat]).addTo(currentMapInstance);const vll=[parseFloat(o.vendorLng||0),parseFloat(o.vendorLat||0)];if(o.vendorLat&&o.vendorLng){fetch(`https://api.mapbox.com/directions/v5/mapbox/driving/${vll[0]},${vll[1]};${geo.lng},${geo.lat}?geometries=geojson&access_token=${MAPBOX_TOKEN}`).then(r=>r.json()).then(rd=>{if(!currentMapInstance||!rd.routes||!rd.routes.length)return;if(currentMapInstance.getSource('route'))currentMapInstance.getSource('route').setData({type:'Feature',properties:{},geometry:rd.routes[0].geometry});else{currentMapInstance.addSource('route',{type:'geojson',data:{type:'Feature',properties:{},geometry:rd.routes[0].geometry}});currentMapInstance.addLayer({id:'route',type:'line',source:'route',layout:{'line-join':'round','line-cap':'round'},paint:{'line-color':'#ff751f','line-width':4,'line-opacity':.8}});}const bounds=new mapboxgl.LngLatBounds().extend(vll).extend([geo.lng,geo.lat]);currentMapInstance.fitBounds(bounds,{padding:40});});}else currentMapInstance.setCenter([geo.lng,geo.lat]);});}
    }catch(e){console.error('Map error:',e);}
  },300);
};

/* ─── NAVIGATION ─────────────────────────── */
function showTab(id,el){
  document.querySelectorAll('#driverMainPanel .page-content').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('#driverSidebar .nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(el)el.classList.add('active');
  if(id==='leaderboard')renderLeaderboard();
  lucide.createIcons();
}
function mobileTab(pageId,btnId){
  document.querySelectorAll('#driverMainPanel .page-content').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.mob-nav-btn').forEach(b=>b.classList.remove('active'));
  const page=document.getElementById(pageId);if(page)page.classList.add('active');
  const btn=document.getElementById(btnId);if(btn)btn.classList.add('active');
  if(pageId==='leaderboard')renderLeaderboard();
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ─── MODALS ─────────────────────────────── */
function openModal(id){const el=document.getElementById(id);el.style.display='flex';setTimeout(()=>{el.classList.add('active');lucide.createIcons();},10);}
function hideModal(id){const el=document.getElementById(id);el.classList.remove('active');setTimeout(()=>el.style.display='none',350);}

function confirmLogout(){
  locBannerShown=false;
  localStorage.removeItem('1busket_driver_session');
  if(locationWatcher){navigator.geolocation.clearWatch(locationWatcher);locationWatcher=null;}
  if(DRIVER_KEY&&isOnline)db.ref('drivers/'+DRIVER_KEY).update({isBusy:false,lastSeen:Date.now()});
  hideModal('logoutModal');
  window.location.href='login.html';
}

/* ─── TOAST ──────────────────────────────── */
function showToast(msg,type='success'){
  const t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  t.className='toast show'+(type==='success'?' success':type==='error'?' error':'');
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show','success','error'),2800);
}

/* ─── SIDEBAR HOVER ──────────────────────── */
const sidebar=document.getElementById('driverSidebar');
if(sidebar){
  sidebar.addEventListener('mouseenter',()=>{sidebar.classList.add('expanded');document.getElementById('driverMainPanel').classList.add('shifted');});
  sidebar.addEventListener('mouseleave',()=>{sidebar.classList.remove('expanded');document.getElementById('driverMainPanel').classList.remove('shifted');});
}

initPortal();
lucide.createIcons();
</script>
</body>
</html>
