<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>1BUSKET | Driver Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-auth.js"></script>
<link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet">
<script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
:root{
  --accent:#ff751f;--accent-dark:#e0621a;--accent-light:#fff3eb;--accent-muted:#ffd9bc;--accent-rgb:255,117,31;
  --store-gradient:linear-gradient(135deg,#ff751f,#e0621a);
  --bg:#fafaf8;--surface:#ffffff;--surface2:#f5f4f1;
  --border:#e8e6e1;--border-strong:#d1cec7;
  --text:#1c1a17;--dim:#6b6560;--text-muted:#a09a92;
  --danger:#d93025;--warning:#ff9500;--green:#1a7a4a;--blue:#1a56a0;
  --sidebar-width:280px;--sidebar-collapsed:72px;
  --radius:16px;--radius-sm:10px;
  --shadow-sm:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --shadow:0 4px 16px rgba(0,0,0,.06),0 2px 6px rgba(0,0,0,.04);
  --shadow-lg:0 20px 60px rgba(0,0,0,.08),0 8px 24px rgba(0,0,0,.05);
  --shadow-hover:0 8px 28px rgba(0,0,0,.10);
  --transition:all 0.3s cubic-bezier(0.4,0,0.2,1);
  --spring:0.4s cubic-bezier(0.34,1.56,0.64,1);
  --mobile-nav-h:64px;
  --safe-bottom:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{height:100%}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;overflow-x:hidden;line-height:1.5;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
input[type="text"],input[type="email"],input[type="tel"],input[type="number"],input[type="password"],input[type="url"],input[type="time"],input[type="file"],select{border-radius:999px!important}
textarea{border-radius:20px!important}

/* OFFLINE BANNER */
#offlineBanner{display:none;position:fixed;top:0;left:0;right:0;z-index:9999;background:linear-gradient(135deg,#1c1a17,#2d2a24);color:white;padding:10px 20px;text-align:center;font-size:.82rem;font-weight:700;align-items:center;justify-content:center;gap:10px}
#offlineBanner.show{display:flex}
.offline-dot{width:8px;height:8px;border-radius:50%;background:#ff4444;animation:pulse-dot 1s infinite}

/* BUSY MODE BANNER */
#busyBanner{display:none;position:fixed;top:0;left:0;right:0;z-index:9998;background:linear-gradient(135deg,#ff9500,#e0821a);color:white;padding:10px 20px;font-size:.82rem;font-weight:700;align-items:center;justify-content:space-between;gap:10px}
#busyBanner.show{display:flex}
#busyBanner.offline-offset{top:40px}
.busy-banner-left{display:flex;align-items:center;gap:8px}
.busy-go-online-btn{background:rgba(255,255,255,.25);border:1.5px solid rgba(255,255,255,.4);color:white;padding:5px 14px;border-radius:999px;font-weight:700;font-size:.78rem;cursor:pointer;font-family:inherit;transition:background .2s}
.busy-go-online-btn:hover{background:rgba(255,255,255,.4)}

/* SHIMMER */
#shimmerOverlay{position:fixed;inset:0;z-index:9999;background:var(--bg);display:none;flex-direction:column;transition:opacity .55s ease}
#shimmerOverlay.active{display:flex}#shimmerOverlay.fade-out{opacity:0;pointer-events:none}
.shim-sidebar{position:absolute;left:0;top:0;width:var(--sidebar-collapsed);height:100%;background:white;border-right:1px solid var(--border);padding:24px 12px;display:flex;flex-direction:column;gap:18px}
.shim-main{margin-left:var(--sidebar-collapsed);flex:1;padding:40px;display:flex;flex-direction:column;gap:28px}
.shim-block{border-radius:20px;background:linear-gradient(90deg,#e8eaed 25%,#f4f5f7 50%,#e8eaed 75%);background-size:400% 100%;animation:shimmerSlide 1.5s ease-in-out infinite}
@keyframes shimmerSlide{0%{background-position:100% 0}100%{background-position:-100% 0}}
.shim-header{height:44px;width:260px;border-radius:999px}.shim-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}.shim-stat{height:110px;border-radius:20px}.shim-row{display:grid;grid-template-columns:1fr 1fr;gap:20px}.shim-card{height:200px;border-radius:20px}

/* DESKTOP SIDEBAR */
.sidebar{width:var(--sidebar-collapsed);background:var(--surface);border-right:1px solid var(--border);padding:24px 12px;position:fixed;height:100vh;z-index:100;display:flex;flex-direction:column;transition:width 0.35s cubic-bezier(0.4,0,0.2,1);overflow:hidden}
.sidebar.expanded{width:var(--sidebar-width);padding:30px 20px}
.logo-wrap{margin-bottom:36px;display:flex;align-items:center;gap:12px;white-space:nowrap;overflow:hidden}
.logo-img{height:32px;width:auto;object-fit:contain;flex-shrink:0}
.logo-text{font-size:1.1rem;font-weight:800;color:var(--text);letter-spacing:-0.5px;opacity:0;transform:translateX(-10px);transition:opacity 0.25s ease,transform 0.25s ease;white-space:nowrap}
.sidebar.expanded .logo-text{opacity:1;transform:translateX(0)}
.nav-section{margin-bottom:24px}
.nav-label{font-size:.68rem;text-transform:uppercase;letter-spacing:1px;color:var(--dim);margin-bottom:10px;padding-left:12px;font-weight:700;white-space:nowrap;opacity:0;transition:opacity 0.2s ease}
.sidebar.expanded .nav-label{opacity:1}
.nav-item{padding:13px 12px;margin-bottom:4px;border-radius:14px;cursor:pointer;transition:var(--transition);font-weight:600;display:flex;align-items:center;gap:12px;color:var(--dim);white-space:nowrap;position:relative}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:var(--accent);color:white}
.nav-icon{flex-shrink:0;width:20px;height:20px}
.nav-text{opacity:0;transform:translateX(-8px);transition:opacity 0.2s ease,transform 0.2s ease}
.sidebar.expanded .nav-text{opacity:1;transform:translateX(0)}
.nav-badge{background:var(--danger);color:white;font-size:.62rem;font-weight:700;padding:1px 6px;border-radius:999px;min-width:18px;text-align:center}
.logout-btn{padding:13px 12px;margin-top:8px;border-radius:14px;cursor:pointer;transition:var(--transition);font-weight:600;display:flex;align-items:center;gap:12px;color:var(--danger);white-space:nowrap;border:none;background:transparent;font-family:inherit;font-size:inherit;width:100%}
.logout-btn:hover{background:#fff1f0}
.user-profile{padding:10px;background:var(--bg);border-radius:14px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:var(--transition);border:1px solid transparent;overflow:hidden;white-space:nowrap}
.user-profile:hover{border-color:var(--border)}
.user-avatar{width:40px;height:40px;border-radius:12px;flex-shrink:0;background:var(--store-gradient);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:.85rem}
.user-info{opacity:0;transform:translateX(-8px);transition:opacity 0.2s ease,transform 0.2s ease}
.sidebar.expanded .user-info{opacity:1;transform:translateX(0)}
.online-dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block;margin-right:4px;animation:pulse-dot 2s infinite}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:0.4}}

/* BUSY STATUS DOT */
.busy-dot{width:8px;height:8px;border-radius:50%;background:#ff9500;display:inline-block;margin-right:4px;animation:pulse-dot 1s infinite}

/* MAIN PANEL */
.main-panel{margin-left:var(--sidebar-collapsed);flex:1;padding:36px;max-width:calc(100% - var(--sidebar-collapsed));transition:margin-left 0.35s cubic-bezier(0.4,0,0.2,1),max-width 0.35s cubic-bezier(0.4,0,0.2,1)}
.main-panel.shifted{margin-left:var(--sidebar-width);max-width:calc(100% - var(--sidebar-width))}
.page-content{display:none;animation:fadeInUp 0.35s ease-out}
.page-content.active{display:block}
@keyframes fadeInUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* HERO */
.dashboard-hero{border-radius:24px;padding:28px 32px;margin-bottom:28px;background:var(--store-gradient);position:relative;overflow:hidden;box-shadow:0 8px 32px rgba(255,117,31,.3)}
.dashboard-hero::before{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.08)}
.dashboard-hero::after{content:'';position:absolute;bottom:-40px;right:80px;width:150px;height:150px;border-radius:50%;background:rgba(255,255,255,.05)}
.hero-inner{position:relative;z-index:2;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px}
.hero-left h1{font-size:1.7rem;font-weight:800;color:white;letter-spacing:-0.5px;margin-bottom:4px}
.hero-left p{color:rgba(255,255,255,.75);font-size:.88rem;font-weight:500}
.hero-emoji{font-size:3.5rem;line-height:1}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:16px;margin-bottom:28px}
.stat-card{background:white;padding:22px;border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border);transition:var(--transition);position:relative;overflow:hidden}
.stat-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-hover)}
.stat-card::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:3px;background:var(--store-gradient);opacity:0;transition:opacity 0.3s}
.stat-card:hover::after{opacity:1}
.stat-icon{position:absolute;right:16px;top:16px;width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;background:var(--accent-light)}
.stat-icon i{width:18px;height:18px;color:var(--accent)}
.stat-card h3{font-size:.7rem;text-transform:uppercase;color:var(--dim);letter-spacing:.5px;margin-bottom:8px;font-weight:700}
.stat-card p{font-size:2rem;font-weight:800;color:var(--text)}

/* CONTENT CARDS */
.content-card{background:white;border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border);overflow:hidden}
.card-header{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.card-header h2{font-size:.95rem;font-weight:700;display:flex;align-items:center;gap:8px}
.order-card{padding:18px 22px;border-bottom:1px solid var(--border);transition:var(--transition)}
.order-card:hover{background:var(--accent-light)}
.order-card:last-child{border-bottom:none}
.order-meta-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:999px;font-size:.72rem;font-weight:700}
.pill-blue{background:var(--accent-light);color:var(--accent-dark)}
.pill-green{background:#edf9f2;color:#1a7a4a}
.pill-yellow{background:#fef9c3;color:#a16207}
.pill-red{background:#fff1f0;color:#d93025}
.pill-gray{background:var(--surface2);color:var(--dim)}

/* BUTTONS */
.btn-primary{background:var(--accent);color:white;border:none;padding:11px 20px;border-radius:999px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;transition:var(--transition);box-shadow:0 4px 14px rgba(255,117,31,.35);font-family:inherit;font-size:.88rem}
.btn-primary:hover{background:var(--accent-dark);transform:translateY(-2px);box-shadow:0 8px 22px rgba(255,117,31,.45)}
.btn{padding:7px 14px;border-radius:999px;border:none;cursor:pointer;font-weight:600;transition:var(--transition);font-size:.8rem;display:inline-flex;align-items:center;gap:5px;font-family:inherit;white-space:nowrap}
.btn-edit{background:var(--surface2);color:var(--text)}.btn-edit:hover{background:var(--border);transform:translateY(-1px)}
.btn-danger{background:#fff1f0;color:var(--danger)}.btn-danger:hover{background:var(--danger);color:white;transform:translateY(-1px)}
.btn-success{background:#edf9f2;color:var(--green)}.btn-success:hover{background:var(--green);color:white;transform:translateY(-1px)}
.btn-warning{background:#fef9c3;color:#a16207}.btn-warning:hover{background:#ff9500;color:white;transform:translateY(-1px)}

/* MODALS */
.modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.45);backdrop-filter:blur(12px);z-index:2000;justify-content:center;align-items:center;opacity:0;transition:opacity .3s ease}
.modal-overlay.active{opacity:1}
.modal-content{background:white;padding:30px;border-radius:24px;width:560px;max-width:95vw;box-shadow:0 32px 64px rgba(0,0,0,.18);transform:scale(0.9) translateY(20px);transition:transform 0.35s cubic-bezier(0.34,1.56,.64,1);max-height:90vh;overflow-y:auto}
.modal-overlay.active .modal-content{transform:scale(1) translateY(0)}
.modal-btn-row{display:flex;gap:12px;margin-top:22px}
.modal-handle{width:40px;height:4px;border-radius:999px;background:var(--border);margin:0 auto 16px;display:none}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--text);color:white;padding:15px 22px;border-radius:999px;box-shadow:var(--shadow-hover);display:flex;align-items:center;gap:12px;transform:translateY(100px);opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);z-index:3000;font-size:.9rem;font-weight:600;max-width:360px}
.toast.show{transform:translateY(0);opacity:1}
.toast.success{border-left:4px solid var(--green)}.toast.error{border-left:4px solid var(--danger)}

/* PROFILE */
.profile-container{max-width:700px}
.profile-hero-card{background:var(--store-gradient);border-radius:24px;padding:32px;margin-bottom:24px;position:relative;overflow:hidden;box-shadow:0 8px 32px rgba(255,117,31,.3)}
.profile-hero-card::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.08)}
.profile-hero-inner{position:relative;z-index:1;display:flex;align-items:center;gap:20px}
.profile-avatar-large{width:72px;height:72px;border-radius:20px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:1.8rem;border:2px solid rgba(255,255,255,.3);flex-shrink:0}
.profile-hero-info h2{color:white;font-size:1.3rem;font-weight:800;margin-bottom:4px}
.profile-hero-info p{color:rgba(255,255,255,.7);font-size:.84rem}
.profile-status-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:999px;padding:5px 14px;color:white;font-size:.76rem;font-weight:700;margin-top:8px}
.profile-section-card{background:white;border-radius:20px;border:1px solid var(--border);box-shadow:var(--shadow);margin-bottom:16px;overflow:hidden}
.profile-section-title{font-size:.72rem;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.8px;padding:16px 20px 0}
.profile-field-row{padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;border-bottom:1px solid var(--border)}
.profile-field-row:last-child{border-bottom:none}
.profile-field-label{font-size:.78rem;color:var(--dim);font-weight:600;margin-bottom:3px}
.profile-pill-input{flex:1;padding:10px 16px;border:1.5px solid var(--border);border-radius:999px;font-family:inherit;font-size:.88rem;outline:none;transition:var(--transition);background:var(--bg);color:var(--text);max-width:280px}
.profile-pill-input:focus{border-color:var(--accent);background:white;box-shadow:0 0 0 3px rgba(255,117,31,.12)}
.profile-pill-input[readonly]{background:var(--accent-light);color:var(--accent-dark);border-color:transparent;cursor:default}

/* SETTINGS */
.settings-container{max-width:700px}
.settings-card{background:white;border-radius:20px;border:1px solid var(--border);box-shadow:var(--shadow);margin-bottom:16px;overflow:hidden}
.settings-card-title{font-size:.72rem;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.8px;padding:16px 20px 0}
.settings-row{display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border);transition:var(--transition)}
.settings-row:last-child{border-bottom:none}
.settings-row:hover{background:var(--surface2)}
.settings-label{font-size:.88rem;font-weight:600;color:var(--text)}
.settings-sub{font-size:.75rem;color:var(--dim);margin-top:2px}
.toggle{width:46px;height:26px;border-radius:999px;background:var(--border);position:relative;cursor:pointer;transition:var(--transition);flex-shrink:0}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:white;box-shadow:0 2px 4px rgba(0,0,0,.15);transition:var(--transition)}
.toggle.on{background:var(--accent)}.toggle.on::after{transform:translateX(20px)}
.toggle.busy-color.on{background:#ff9500}

/* BUSY MODE SELECTOR */
.busy-reason-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:16px 0}
.busy-reason-btn{padding:14px;border-radius:16px;border:2px solid var(--border);background:var(--surface2);cursor:pointer;text-align:center;transition:var(--transition);font-family:inherit}
.busy-reason-btn:hover{border-color:var(--warning);background:#fef9c3}
.busy-reason-btn.selected{border-color:var(--warning);background:#fef9c3;box-shadow:0 0 0 3px rgba(255,149,0,.15)}
.busy-reason-btn .reason-icon{font-size:1.6rem;margin-bottom:6px}
.busy-reason-btn .reason-label{font-size:.82rem;font-weight:700;color:var(--text)}

/* MAP */
.map-container{width:100%;height:280px;border-radius:16px;overflow:hidden;margin-top:12px;border:1px solid var(--border)}
#orderMap{width:100%;height:100%}
.order-detail-section{margin-bottom:18px}
.order-detail-section h4{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--dim);margin-bottom:10px}
.addr-display{background:var(--accent-light);border:1px solid rgba(255,117,31,.2);border-radius:14px;padding:12px 16px;display:flex;align-items:flex-start;gap:10px}
.addr-display.pickup{background:#edf9f2;border:1px solid #bbf0d3}
.addr-display.delivery{background:var(--accent-light);border:1px solid rgba(255,117,31,.2)}
.addr-display.locked{background:#fef9c3;border:1px solid #fcd34d}

/* ROUTE OPTIMIZATION CARD */
.route-card{background:linear-gradient(135deg,#1c1a17,#2d2a24);border-radius:20px;padding:20px;margin-bottom:20px;color:white;position:relative;overflow:hidden}
.route-card::before{content:'';position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,117,31,.15)}
.route-card-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:rgba(255,255,255,.6);margin-bottom:10px}
.route-card h3{font-size:1.05rem;font-weight:800;margin-bottom:16px}
.route-stops{display:flex;flex-direction:column;gap:0}
.route-stop{display:flex;align-items:flex-start;gap:12px;padding:8px 0;position:relative}
.route-stop:not(:last-child)::after{content:'';position:absolute;left:13px;top:28px;width:2px;height:calc(100% - 10px);background:rgba(255,255,255,.2)}
.route-stop-num{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;flex-shrink:0;z-index:1}
.route-stop-num.pickup{background:#1a7a4a;color:white}
.route-stop-num.delivery{background:var(--accent);color:white}
.route-stop-info{flex:1}
.route-stop-type{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;opacity:.6;margin-bottom:2px}
.route-stop-addr{font-size:.82rem;font-weight:600;line-height:1.4}
.route-map-wrap{height:200px;border-radius:14px;overflow:hidden;margin-top:14px;border:1px solid rgba(255,255,255,.1)}
#routeOptMap{width:100%;height:100%}

/* PHOTO PROOF */
.proof-upload-area{border:2.5px dashed var(--border);border-radius:20px;padding:32px;text-align:center;cursor:pointer;transition:var(--transition);background:var(--surface2);position:relative;margin:16px 0}
.proof-upload-area:hover{border-color:var(--accent);background:var(--accent-light)}
.proof-upload-area.has-photo{border-color:var(--green);background:#edf9f2;border-style:solid}
.proof-upload-area input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.proof-preview{width:100%;height:180px;object-fit:cover;border-radius:14px;display:none;margin-bottom:12px}
.proof-preview.show{display:block}
.proof-upload-icon{font-size:2.4rem;margin-bottom:8px}
.proof-upload-label{font-size:.9rem;font-weight:700;color:var(--dim);margin-bottom:4px}
.proof-upload-sub{font-size:.75rem;color:var(--text-muted)}
.proof-uploading{display:none;align-items:center;gap:10px;justify-content:center;padding:12px 0;color:var(--accent);font-weight:600;font-size:.85rem}
.proof-uploading.show{display:flex}

/* LEADERBOARD */
.leaderboard-container{max-width:700px}
.leaderboard-header-card{background:linear-gradient(135deg,#1c1a17 0%,#3d3630 100%);border-radius:24px;padding:28px 32px;margin-bottom:20px;position:relative;overflow:hidden}
.leaderboard-header-card::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,117,31,.12)}
.leaderboard-header-card h2{color:white;font-size:1.4rem;font-weight:800;margin-bottom:4px;position:relative}
.leaderboard-header-card p{color:rgba(255,255,255,.6);font-size:.84rem;position:relative}
.leaderboard-province-filter{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.province-chip{padding:8px 16px;border-radius:999px;border:1.5px solid var(--border);background:var(--surface);cursor:pointer;font-size:.78rem;font-weight:700;color:var(--dim);transition:var(--transition);font-family:inherit}
.province-chip:hover{border-color:var(--accent-muted);color:var(--accent)}
.province-chip.active{background:var(--accent);border-color:var(--accent);color:white}
.leaderboard-row{display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:16px;margin-bottom:8px;background:white;border:1px solid var(--border);transition:var(--transition)}
.leaderboard-row:hover{box-shadow:var(--shadow);transform:translateY(-1px)}
.leaderboard-row.is-me{background:var(--accent-light);border-color:var(--accent-muted);box-shadow:0 0 0 2px rgba(255,117,31,.15)}
.leaderboard-row.rank-1{background:linear-gradient(135deg,#fffbeb,#fef3c7);border-color:#fcd34d}
.leaderboard-row.rank-2{background:linear-gradient(135deg,#f9fafb,#f1f5f9);border-color:#cbd5e1}
.leaderboard-row.rank-3{background:linear-gradient(135deg,#fff7ed,#ffedd5);border-color:#fed7aa}
.leaderboard-rank{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;flex-shrink:0}
.rank-1 .leaderboard-rank{background:linear-gradient(135deg,#f59e0b,#d97706);color:white}
.rank-2 .leaderboard-rank{background:linear-gradient(135deg,#94a3b8,#64748b);color:white}
.rank-3 .leaderboard-rank{background:linear-gradient(135deg,#fb923c,#ea580c);color:white}
.leaderboard-rank-default{background:var(--surface2);color:var(--dim)}
.leaderboard-avatar{width:40px;height:40px;border-radius:12px;background:var(--store-gradient);color:white;font-weight:800;font-size:.95rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.leaderboard-info{flex:1;min-width:0}
.leaderboard-name{font-weight:700;font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.leaderboard-sub{font-size:.72rem;color:var(--dim)}
.leaderboard-score{text-align:right;flex-shrink:0}
.leaderboard-deliveries{font-size:1.1rem;font-weight:800;color:var(--text)}
.leaderboard-earn{font-size:.72rem;color:var(--green);font-weight:700}
.you-badge{background:var(--accent);color:white;font-size:.6rem;font-weight:700;padding:2px 7px;border-radius:999px;margin-left:6px}
.leaderboard-trophy{font-size:1.4rem}

/* MISC */
.empty-state{text-align:center;padding:48px 24px;color:var(--dim)}
.history-card{background:white;border-radius:16px;padding:16px 20px;border:1px solid var(--border);margin-bottom:12px;transition:var(--transition)}
.history-card:hover{box-shadow:var(--shadow-hover);transform:translateY(-2px)}
.customer-name-badge{display:inline-flex;align-items:center;gap:6px;background:var(--surface2);border-radius:999px;padding:3px 12px;font-size:.7rem;font-weight:600;color:var(--accent);margin-left:8px}
.location-banner{background:linear-gradient(135deg,#fef3c7,#fde68a);border:1px solid #fcd34d;border-radius:16px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;gap:12px;font-size:.84rem;font-weight:600;color:#92400e}
.location-banner.success{background:linear-gradient(135deg,#edf9f2,#bbf0d3);border-color:#86efac;color:#14532d}
.location-banner.error{background:linear-gradient(135deg,#fff1f0,#fcd9d7);border-color:#fca5a5;color:#7f1d1d}

/* ══════════════════════════
   MOBILE STYLES
══════════════════════════ */
@media(min-width:769px){
  .mobile-topbar,.mobile-bottom-nav{display:none!important}
  .hero-stats-row{display:none!important}
  .mob-only{display:none!important}
  .dash-two-col{display:grid;grid-template-columns:1fr 340px;gap:20px}
}
@media(max-width:768px){
  .sidebar{display:none!important}.shim-sidebar{display:none!important}
  .shim-main{margin-left:0!important;padding:20px 16px!important}
  .main-panel{margin-left:0!important;max-width:100%!important;padding:calc(60px + 14px) 0 calc(var(--mobile-nav-h) + var(--safe-bottom) + 14px)!important;display:block!important}
  .main-panel.shifted{margin-left:0!important;max-width:100%!important}
  .mobile-topbar{display:flex!important;align-items:center;justify-content:space-between;padding:0 16px;background:var(--surface);border-bottom:1px solid var(--border);position:fixed;top:0;left:0;right:0;z-index:200;height:60px;box-shadow:0 2px 12px rgba(0,0,0,.06)}
  .mob-logo-img{height:28px;width:auto;object-fit:contain}
  .mob-topbar-right{display:flex;align-items:center;gap:10px}
  .mob-loc{font-size:11px;color:var(--dim);font-weight:600;display:flex;align-items:center;gap:4px}
  .mob-avatar{width:36px;height:36px;border-radius:10px;background:var(--store-gradient);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:.85rem;cursor:pointer;transition:transform .2s}
  .mob-avatar:active{transform:scale(.92)}
  .mobile-bottom-nav{display:flex!important;position:fixed;bottom:0;left:0;right:0;height:calc(var(--mobile-nav-h) + var(--safe-bottom));background:var(--surface);border-top:1px solid var(--border);z-index:200;align-items:flex-start;padding-top:6px;box-shadow:0 -4px 20px rgba(0,0,0,.08)}
  .mob-nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 4px 4px;border:none;background:transparent;cursor:pointer;color:var(--text-muted);font-family:'Plus Jakarta Sans',sans-serif;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;transition:color .25s;position:relative}
  .mob-nav-btn.active{color:var(--accent)}
  .mob-nav-btn svg{width:22px;height:22px;stroke:currentColor;transition:transform .35s cubic-bezier(.34,1.56,.64,1)}
  .mob-nav-btn.active svg{transform:translateY(-2px)}
  .mob-nav-btn::before{content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%) scaleX(0);width:26px;height:3px;background:var(--accent);border-radius:0 0 3px 3px;transition:transform .35s cubic-bezier(.34,1.56,.64,1)}
  .mob-nav-btn.active::before{transform:translateX(-50%) scaleX(1)}
  .mob-nav-badge{position:absolute;top:2px;right:calc(50% - 20px);background:var(--danger);color:white;font-size:9px;font-weight:700;padding:1px 5px;border-radius:999px;min-width:16px;text-align:center;border:2px solid var(--surface);transform:scale(0);transition:transform .35s cubic-bezier(.34,1.56,.64,1)}
  .mob-nav-badge.visible{transform:scale(1)}
  .dashboard-hero{border-radius:18px;padding:18px;margin:0 0 14px}
  .hero-left h1{font-size:1.15rem}.hero-left p{font-size:.76rem}.hero-emoji{font-size:2.4rem}
  .hero-stats-row{display:flex!important;gap:8px;margin-top:14px;position:relative;z-index:2}
  .hero-stat-pill{flex:1;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.22);border-radius:12px;padding:9px 6px;text-align:center}
  .hero-stat-pill .val{font-size:17px;font-weight:800;color:#fff}
  .hero-stat-pill .lbl{font-size:9px;color:rgba(255,255,255,.72);text-transform:uppercase;letter-spacing:.4px;font-weight:700;margin-top:2px}
  .mob-pg{padding:0 14px}
  .mob-section-lbl{font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.6px;display:flex;align-items:center;gap:8px;margin:18px 0 10px}
  .mob-count-chip{background:var(--accent);color:white;font-size:9.5px;padding:2px 7px;border-radius:999px;font-weight:700}
  .mob-order-list{display:flex;flex-direction:column;gap:10px}
  .mob-card{background:var(--surface);border-radius:18px;border:1px solid var(--border);box-shadow:0 2px 10px rgba(0,0,0,.05);overflow:hidden;animation:mobCardIn .35s cubic-bezier(.34,1.2,.64,1) both;transition:transform .18s,box-shadow .18s}
  .mob-card:active{transform:scale(.985);box-shadow:none}
  @keyframes mobCardIn{from{opacity:0;transform:translateY(10px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
  .mob-card-head{padding:13px 14px 10px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
  .mob-vendor-name{font-size:14.5px;font-weight:800;color:var(--text)}
  .mob-order-num{font-size:11px;color:var(--text-muted);font-weight:600;margin-top:1px}
  .mob-order-amount{font-size:18px;font-weight:800;color:var(--accent);white-space:nowrap}
  .mob-addr-row{margin:0 14px 11px;padding:10px 12px;border-radius:12px;display:flex;gap:9px;align-items:flex-start}
  .mob-addr-row.pickup{background:#edf9f2;border:1px solid rgba(26,122,74,.18)}
  .mob-addr-row.delivery{background:var(--accent-light);border:1px solid rgba(255,117,31,.18)}
  .mob-addr-row.locked{background:#fef9c3;border:1px solid rgba(252,211,77,.6)}
  .mob-addr-row svg{width:15px;height:15px;flex-shrink:0;margin-top:2px}
  .mob-addr-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
  .mob-addr-row.pickup .mob-addr-lbl{color:var(--green)}.mob-addr-row.delivery .mob-addr-lbl{color:var(--accent-dark)}.mob-addr-row.locked .mob-addr-lbl{color:#92400e}
  .mob-addr-val{font-size:12px;font-weight:600;line-height:1.4}
  .mob-addr-row.pickup .mob-addr-val{color:#065F46}.mob-addr-row.delivery .mob-addr-val{color:#7C2D12}.mob-addr-row.locked .mob-addr-val{color:#92400e;font-size:11.5px}
  .mob-card-foot{padding:8px 14px 13px;display:flex;gap:7px;align-items:center;flex-wrap:wrap}
  .mob-meta-row{display:flex;gap:6px;flex:1;flex-wrap:wrap;align-items:center}
  .mob-chip{display:inline-flex;align-items:center;gap:4px;background:var(--surface2);border:1px solid var(--border);border-radius:999px;padding:4px 9px;font-size:10.5px;font-weight:600;color:var(--dim)}
  .mob-chip svg{width:10px;height:10px}
  .mob-btn-row{display:flex;gap:7px;flex-shrink:0}
  .mob-btn{display:inline-flex;align-items:center;gap:5px;padding:9px 13px;border-radius:999px;border:none;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;transition:transform .2s;white-space:nowrap}
  .mob-btn:active{transform:scale(.91)}.mob-btn svg{width:13px;height:13px}
  .mob-btn-accept{background:var(--green);color:#fff;box-shadow:0 3px 10px rgba(26,122,74,.3)}
  .mob-btn-reveal{background:var(--accent);color:#fff;box-shadow:0 3px 10px rgba(255,117,31,.3)}
  .mob-btn-done{background:var(--accent);color:#fff;box-shadow:0 3px 10px rgba(255,117,31,.3)}
  .mob-btn-outline{background:var(--surface2);color:var(--text);border:1px solid var(--border-strong)}
  .mob-btn-del{background:#fff1f0;color:var(--danger)}
  .mob-btn-proof{background:linear-gradient(135deg,#1a56a0,#1a3a7a);color:#fff;box-shadow:0 3px 10px rgba(26,86,160,.3)}
  .mob-status-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;font-size:10px;font-weight:700;white-space:nowrap}
  .mob-status-pill.assigned{background:#fef9c3;color:#a16207}
  .mob-status-pill.out_for_delivery{background:var(--accent-light);color:var(--accent-dark)}
  .desk-only{display:none!important}.mob-only{display:block!important}
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px}
  .stat-card{padding:14px;border-radius:14px}.stat-card p{font-size:1.5rem}.stat-card h3{font-size:.62rem}
  .stat-icon{width:30px;height:30px;border-radius:8px;right:10px;top:10px}.stat-icon i{width:14px;height:14px}
  .profile-container{max-width:100%}.profile-hero-card{padding:22px;border-radius:18px;margin-bottom:16px}
  .profile-avatar-large{width:56px;height:56px;font-size:1.4rem}.profile-hero-info h2{font-size:1.1rem}
  .profile-field-row{flex-direction:column;align-items:flex-start;gap:8px}.profile-pill-input{max-width:100%;width:100%}
  .settings-container{max-width:100%}
  .history-card{border-radius:14px;padding:13px 14px}
  .modal-overlay{align-items:flex-end!important}
  .modal-content{width:100%!important;max-width:100%!important;border-radius:24px 24px 0 0!important;padding:18px 18px calc(var(--safe-bottom) + 20px)!important;transform:translateY(100%)!important;max-height:92vh!important;transition:transform .4s cubic-bezier(.34,1.2,.64,1)!important}
  .modal-overlay.active .modal-content{transform:translateY(0)!important}
  .modal-handle{display:block!important}
  .modal-btn-row{flex-direction:column!important}
  .modal-btn-row .btn{justify-content:center!important;padding:13px!important;font-size:.88rem!important;border-radius:14px!important}
  .toast{bottom:calc(var(--mobile-nav-h) + var(--safe-bottom) + 10px);right:12px;left:12px;max-width:100%;border-radius:14px}
  .page-content>h1{font-size:1.4rem!important;margin-bottom:18px!important;padding:0 14px}
  .map-container{height:200px}
  .leaderboard-container{max-width:100%}
  .busy-reason-grid{grid-template-columns:1fr 1fr}
  .route-card{border-radius:16px;padding:16px}
}
@keyframes spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
.spin{animation:spin 1s linear infinite}
</style>
</head>
<body>

<!-- OFFLINE BANNER -->
<div id="offlineBanner">
  <div class="offline-dot"></div>
  <span>You're offline — orders will sync when back online</span>
</div>

<!-- BUSY MODE BANNER -->
<div id="busyBanner">
  <div class="busy-banner-left">
    <span style="font-size:1.1rem">⏸</span>
    <span>Busy mode: <strong id="busyReasonLabel">On break</strong> — not receiving new orders</span>
  </div>
  <button class="busy-go-online-btn" onclick="goOnlineFromBanner()">Go Online</button>
</div>

<!-- SHIMMER -->
<div id="shimmerOverlay">
  <div class="shim-sidebar"></div>
  <div class="shim-main">
    <div class="shim-block shim-header"></div>
    <div class="shim-stats"><div class="shim-block shim-stat"></div><div class="shim-block shim-stat"></div><div class="shim-block shim-stat"></div><div class="shim-block shim-stat"></div></div>
    <div class="shim-row"><div class="shim-block shim-card"></div><div class="shim-block shim-card"></div></div>
  </div>
</div>

<!-- MOBILE TOP BAR -->
<div class="mobile-topbar" id="mobileTopbar" style="display:none">
  <img src="https://i.postimg.cc/65pML87d/1BUSKET-LOGO.png" class="mob-logo-img" alt="1BUSKET">
  <div class="mob-topbar-right">
    <div class="mob-loc" id="mobLocStatus"><i data-lucide="map-pin"></i> Locating…</div>
    <div class="mob-avatar" id="mobAvatar" onclick="mobileTab('profile','mnp')">D</div>
  </div>
</div>

<!-- DESKTOP SIDEBAR -->
<nav class="sidebar" id="driverSidebar">
  <div class="logo-wrap">
    <img src="https://i.postimg.cc/65pML87d/1BUSKET-LOGO.png" alt="1BUSKET" class="logo-img">
    <span class="logo-text">1BUSKET</span>
  </div>
  <div style="flex:1;overflow-y:auto">
    <div class="nav-section">
      <div class="nav-label">Main</div>
      <div class="nav-item active" onclick="showTab('dashboard',this)"><i data-lucide="layout-dashboard" class="nav-icon"></i><span class="nav-text">Dashboard</span></div>
      <div class="nav-item" onclick="showTab('available',this)"><i data-lucide="shopping-bag" class="nav-icon"></i><span class="nav-text">Available Orders</span><span class="nav-badge" id="availableBadge" style="display:none">0</span></div>
      <div class="nav-item" onclick="showTab('deliveries',this)"><i data-lucide="map-pin" class="nav-icon"></i><span class="nav-text">My Deliveries</span></div>
      <div class="nav-item" onclick="showTab('history',this)"><i data-lucide="clock" class="nav-icon"></i><span class="nav-text">Order History</span></div>
      <div class="nav-item" onclick="showTab('earnings',this)"><i data-lucide="dollar-sign" class="nav-icon"></i><span class="nav-text">Earnings</span></div>
      <div class="nav-item" onclick="showTab('leaderboard',this)"><i data-lucide="trophy" class="nav-icon"></i><span class="nav-text">Leaderboard</span></div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Account</div>
      <div class="nav-item" onclick="showTab('profile',this)"><i data-lucide="user" class="nav-icon"></i><span class="nav-text">Profile</span></div>
      <div class="nav-item" onclick="showTab('settings',this)"><i data-lucide="settings" class="nav-icon"></i><span class="nav-text">Settings</span></div>
      <button class="logout-btn" onclick="openModal('logoutModal')"><i data-lucide="log-out" class="nav-icon"></i><span class="nav-text">Log Out</span></button>
    </div>
  </div>
  <div class="user-profile" onclick="showTab('profile',null)">
    <div class="user-avatar" id="driverAvatar">D</div>
    <div class="user-info">
      <div style="font-weight:700" id="driverSidebarName">Driver</div>
      <div style="font-size:.72rem;color:var(--accent)" id="sidebarStatusLine"><span class="online-dot"></span>Online</div>
    </div>
  </div>
</nav>

<!-- MAIN PANEL -->
<main class="main-panel" id="driverMainPanel">

  <!-- DASHBOARD -->
  <section id="dashboard" class="page-content active">
    <div id="locationBanner" class="location-banner" style="display:none"></div>
    <!-- Route optimization card (shown when 2+ active) -->
    <div id="routeOptCard" style="display:none" class="mob-pg desk-padding">
      <div class="route-card">
        <div class="route-card-title">🗺 Route Optimisation</div>
        <h3>Combined delivery route</h3>
        <div class="route-stops" id="routeStopList"></div>
        <div class="route-map-wrap"><div id="routeOptMap"></div></div>
        <div style="margin-top:12px">
          <button onclick="openGoogleMapsRoute()" class="btn-primary" style="width:100%;justify-content:center">
            <i data-lucide="navigation" style="width:15px;height:15px"></i> Open Full Route in Google Maps
          </button>
        </div>
      </div>
    </div>
    <div class="dashboard-hero">
      <div class="hero-inner">
        <div class="hero-left"><h1 id="dashHeroTitle">Ready to Ride? 🛵</h1><p id="dashHeroSub">Available deliveries near you</p></div>
        <div class="hero-emoji">🛵</div>
      </div>
      <div class="hero-stats-row" id="heroStatsRow">
        <div class="hero-stat-pill"><div class="val" id="hStatToday">0</div><div class="lbl">Today</div></div>
        <div class="hero-stat-pill"><div class="val" id="hStatEarn">R0</div><div class="lbl">Earned</div></div>
        <div class="hero-stat-pill"><div class="val" id="hStatRating">5.0★</div><div class="lbl">Rating</div></div>
        <div class="hero-stat-pill"><div class="val" id="hStatActive">0</div><div class="lbl">Active</div></div>
      </div>
    </div>
    <div class="stats-grid" id="driverStatsGrid"></div>
    <div class="mob-only mob-pg">
      <div class="mob-section-lbl">Available Orders <span class="mob-count-chip" id="mobAvailChip">0</span></div>
      <div class="mob-order-list" id="mobAvailList"></div>
      <div class="mob-section-lbl" style="margin-top:20px">My Active Deliveries</div>
      <div class="mob-order-list" id="mobActiveList"></div>
    </div>
    <div class="dash-two-col desk-only">
      <div class="content-card">
        <div class="card-header"><h2><i data-lucide="shopping-bag" style="width:18px;height:18px;color:var(--accent)"></i> Available Orders <span id="availableCount" style="background:var(--accent);color:white;border-radius:999px;padding:2px 8px;font-size:.72rem;margin-left:4px">0</span></h2></div>
        <div id="availableOrdersList" style="padding:16px;max-height:420px;overflow-y:auto"></div>
      </div>
      <div class="content-card">
        <div class="card-header"><h2><i data-lucide="map-pin" style="width:18px;height:18px;color:var(--accent)"></i> My Active Deliveries</h2></div>
        <div id="myDeliveriesList" style="padding:16px;max-height:420px;overflow-y:auto"></div>
      </div>
    </div>
  </section>

  <!-- AVAILABLE -->
  <section id="available" class="page-content">
    <h1 style="font-size:1.9rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:26px">Available Orders</h1>
    <div id="locationBanner2" class="location-banner" style="display:none;margin-bottom:16px"></div>
    <div class="mob-only mob-pg"><div class="mob-order-list" id="mobAvailFull"></div></div>
    <div class="desk-only content-card" id="availableFullList" style="padding:0"></div>
  </section>

  <!-- DELIVERIES -->
  <section id="deliveries" class="page-content">
    <h1 style="font-size:1.9rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:26px">My Current Deliveries</h1>
    <div class="mob-only mob-pg"><div class="mob-order-list" id="mobDelivFull"></div></div>
    <div class="desk-only content-card" id="myDeliveriesFullList" style="padding:0"></div>
  </section>

  <!-- HISTORY -->
  <section id="history" class="page-content">
    <h1 style="font-size:1.9rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:26px">Order History</h1>
    <div id="orderHistoryList" class="mob-pg"></div>
  </section>

